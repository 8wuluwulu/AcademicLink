# ========================================
# AcademicLink — Environment Configuration
# ========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# Telegram Bot
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/academiclink

# API Security
SECRET_KEY=change-me-to-a-random-64-char-string

# Default Tutor (seeds the DB on first run if no tutor exists)
DEFAULT_TUTOR_TG_ID=123456789
DEFAULT_TUTOR_NAME=Tutor

# Environment: development | production
ENVIRONMENT=development
